{
  "name": "idle-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:shared": "npm run --prefix ../shared build",
    "predev": "npm run build:shared",
    "prebuild": "npm run build:shared",
    "pretest": "npm run build:shared",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview",
    "api:types:generate": "openapi-ts -i ../idle-backend/openapi/openapi.json -o src/app/generated/api-types.ts",
    "api:types:check": "npm run api:types:generate && git diff --exit-code -- src/app/generated/api-types.ts"
  },
  "dependencies": {
    "@maxidle/shared": "file:../shared",
    "better-auth": "^1.6.6",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "react-share": "^5.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@hey-api/openapi-ts": "^0.96.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^3.2.4"
  }
}
