{
  "name": "idle-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MVP backend for Max Idle",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "migrate": "tsx scripts/migrate.ts",
    "test": "vitest run",
    "openapi:generate": "tsx scripts/generateOpenApi.ts",
    "openapi:check": "npm run openapi:generate && git diff --exit-code -- openapi/openapi.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "@maxidle/shared": "file:../shared",
    "@opentelemetry/api": "^1.9.1",
    "better-auth": "^1.6.5",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.8.1",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/supertest": "^6.0.3",
    "pg-mem": "^3.0.5",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
