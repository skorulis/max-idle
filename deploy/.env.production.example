# Domains
APP_DOMAIN=app.max-idle.com
API_DOMAIN=api.max-idle.com

# Image locations
BACKEND_IMAGE_REPO=ghcr.io/your-org/maxidle-backend
FRONTEND_IMAGE_REPO=ghcr.io/your-org/maxidle-frontend
IMAGE_TAG=latest

# Database
POSTGRES_DB=max_idle
POSTGRES_USER=maxidle
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgres://maxidle:replace-with-strong-password@postgres:5432/max_idle

# Backend runtime
PORT=3000
JWT_SECRET=replace-with-long-random-secret
CORS_ORIGIN=https://app.max-idle.com
BETTER_AUTH_SECRET=replace-with-long-random-secret
BETTER_AUTH_URL=https://api.max-idle.com

# Optional OAuth (prepare now for future enablement)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
